{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "repairfront.com" }],
      "destination": "https://www.repairfront.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html|/|/index)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
